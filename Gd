#include <stdio.h>

int main() {
    int i;
    float numero, soma = 0;

    for(i = 1; i <= 5; i++) {
        printf("Digite o %dº número: ", i);
        scanf("%f", &numero);

        if(numero > 0) {
            soma += numero;
        }
    }

    printf("A soma dos números positivos é: %.2f\n", soma);

    return 0;
}